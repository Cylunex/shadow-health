.env
__pycache__/
# 私人内容素材不入仓（seed 会自动跳过，见 app/seed/data/README.md）
app/seed/data/*.md
!app/seed/data/README.md
*.pyc
.venv/
tools/
uploads/
*.egg-info/
.pytest_cache/
dist/
# Android Gradle 工程产物与本机配置
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/libs/*.aar
.DS_Store
# 手机安装包（构建产物，放 static/ 供局域网下载）
static/*.apk
