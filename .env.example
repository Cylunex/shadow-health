# 复制为 .env 并填值；一切凭据只存 .env，不进仓库（设计文档 §7.1）
DATABASE_URL=postgresql+psycopg://health_app:CHANGE_ME@127.0.0.1:55433/health_dev
# 用 python -m app.auth hash <你的密码> 生成
AUTH_PASSWORD_HASH=
# 用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
SESSION_SECRET=
INGEST_TOKEN=
# Keep 账号（M4b 可选，未定前留空）
KEEP_MOBILE=
KEEP_PASSWORD=
APP_PORT=8080
# 生产 compose 的 backup 服务连接项（宿主机 PG 的局域网地址等）
BACKUP_PG_HOST=
BACKUP_PG_PORT=55432
BACKUP_PG_DB=shadow_health
BACKUP_PG_USER=health_app
BACKUP_PG_PASSWORD=
# AI 智能分析（可选）：填 Anthropic API Key 后 /ai 页面可用；走代理再设 BASE_URL
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
LLM_MODEL=claude-opus-4-8
